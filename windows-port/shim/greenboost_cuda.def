; GreenBoost v2.3 — DLL export definitions
;
; When used as a proxy DLL (nvcuda.dll replacement), these exports
; forward to the real nvcuda_real.dll. When used as a Detours-injected
; DLL, only DllMain is needed (hooks are installed via DetourAttach).

LIBRARY greenboost_cuda

EXPORTS
    DllMain             @1
